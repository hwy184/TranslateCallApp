NODE_ENV=development
PORT=3000
TRUST_PROXY_HOPS=1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_ROOMS_MAX=60
RATE_LIMIT_GLOBAL_MAX=120
ROOM_LOCK_MINUTES=3
LIVEKIT_URL=wss://your-livekit-host.example
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
JWT_SECRET=change-me-super-secret-key
WORKER_INTERNAL_SECRET=change-me-worker-secret
WORKER_INTERNAL_URL=http://worker:8000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_translation
