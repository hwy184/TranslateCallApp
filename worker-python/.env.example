APP_NAME=voice-worker
PORT=8000
LOG_LEVEL=INFO
LIVEKIT_URL=wss://your-livekit-host.example
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_BRIDGE_ENABLED=true
LIVEKIT_WORKER_IDENTITY_PREFIX=ai_worker_
BACKEND_EVENTS_URL=http://backend:3000/api/v1/internal/worker/events
BACKEND_EVENTS_TIMEOUT_SEC=3
BACKEND_EVENTS_RETRIES=2
DEFAULT_PROVIDER_PROFILE=google-first
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TRANSLATE_MODEL=gemma4:e4b
OLLAMA_TRANSLATE_TIMEOUT_SEC=75
OPENAI_API_KEY=
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=whisper-1
GEMINI_API_KEY=
GEMINI_TRANSLATE_MODEL=gemini-2.5-flash
GEMINI_STT_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
GOOGLE_CLOUD_PROJECT=
GOOGLE_TRANSLATE_LOCATION=global
LOCAL_STT_ENABLED=false
LOCAL_STT_MODEL_SIZE=base
LOCAL_STT_COMPUTE_TYPE=int8
LOCAL_STT_DEVICE=cpu
STT_ENERGY_THRESHOLD=220
STT_MIN_SPEECH_MS=550
STT_MIN_VOICED_MS=80
STT_MIN_VOICED_RATIO=0.18
STT_SILENCE_HANGOVER_MS=700
STT_MAX_SEGMENT_MS=5000
STT_MIN_REQUEST_INTERVAL_MS=350
STT_DUPLICATE_SUPPRESS_WINDOW_MS=3500
STT_FORCE_SEGMENT_PEAK_RMS=4500
STT_FORCE_SEGMENT_MIN_VOICED_MS=80
EDGE_TTS_VOICE_DEFAULT=en-US-AriaNeural
EDGE_TTS_RATE=+0%
